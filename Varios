// ── Método refactorizado usando .Where() encadenados ──
// Reemplaza el QueryMaker de 16 escenarios

private QueryBuilder<CYBFAV> BuildQuery(FiltroFavoritos filtro, QueryBuilderOptions db2Options)
{
    var query = new QueryBuilder<CYBFAV>(db2Options)
        .Select()
        .Where(item => item.NumeroIdentidadOrigen == filtro.NumeroIdentificacion);

    if (filtro.TieneNombreTitular)
        query = query.Where(item => item.NombreTitular.Contains(filtro.NombreTitular));

    if (filtro.TieneAlias)
        query = query.Where(item => item.AliasCuenta.Contains(filtro.Alias));

    if (filtro.TieneCuentaDestino)
        query = query.Where(item => item.NumeroCuentaDestino.Contains(filtro.CuentaDestino));

    if (filtro.TieneCuentaACH)
        query = query.Where(item => item.NumeroCuentaOrigen.Contains(filtro.CuentaACH));

    return query.OrderByDescending(item => item.FechaHoraCreacion);
}


// ── Uso ──
var query = BuildQuery(filtro, db2Options).Build();

await using var connection = _connectionFactory.Create();
await connection.OpenAsync(cancellationToken);

var resultados = await connection.QueryAsync<CYBFAV>(
    query.Sql,
    query.ToDapperParameters());
