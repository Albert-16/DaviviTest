            else if (codTipoCuentaDestino.Trim() == "6")
            {
                Props.DataList.Add(GenProp("familia", "CTAS"));
                Props.DataList.Add(GenProp("grupo", "CTA02"));
                Props.DataList.Add(GenProp("codigoProducto", "6"));
            }
