                        codTipoCuentaDestino = "50";
                        break;
                    case "S"://
                        codTipoCuentaDestino = "60";
                        break;
                    case "T"://Tarjetas de credito
                        codTipoCuentaDestino = "89";
                        break;
                    case "G"://Seguros
